# Database
DATABASE_URL="postgresql://user:password@localhost:5432/limitless_cubes?schema=public"

# LIMITLESS SSO — shared secret with PATHS (Payload CMS)
PAYLOAD_SECRET="must-match-paths-payload-secret"

# Service-to-service keys
CUBES_DT_SERVICE_KEY="generate-random-key-for-dt"
PATHS_CUBES_SERVICE_KEY="generate-random-key-for-paths"
HUB_CUBES_SERVICE_KEY="generate-random-key-for-hub"

# Cloudinary (exercise media)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Base path (set to /train in production behind gateway)
NEXT_PUBLIC_BASE_PATH=""
